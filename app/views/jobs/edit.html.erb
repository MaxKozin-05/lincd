<div class="relative isolate overflow-hidden bg-white py-12 text-slate-900 rounded-3xl">
  <div class="absolute inset-0 pointer-events-none opacity-50">
    <div class="absolute -top-12 -left-16 h-64 w-64 rounded-full bg-slate-200 blur-[120px]"></div>
    <div class="absolute top-1/3 right-0 h-72 w-72 rounded-full bg-slate-100 blur-[140px]"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-6 lg:px-0 space-y-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div class="space-y-2">
        <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Jobs</p>
        <h1 class="text-3xl md:text-4xl font-bold text-slate-900">Edit Role</h1>
        <p class="text-slate-500">Update the job details shown on the public jobs board.</p>
      </div>
      <%= link_to "Back to Jobs", jobs_path, class: "inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50" %>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white/80 backdrop-blur p-8 shadow-2xl shadow-slate-200/70">
      <%= render "form", job: @job %>
    </div>
  </div>
</div>
