<div class="relative isolate overflow-hidden bg-white py-20 text-slate-900 min-h-screen">
  <div class="absolute inset-0 pointer-events-none opacity-50">
    <div class="absolute -top-20 -left-16 h-72 w-72 rounded-full bg-slate-200 blur-[140px]"></div>
    <div class="absolute top-1/3 right-0 h-96 w-96 rounded-full bg-slate-100 blur-[180px]"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-6 lg:px-0 space-y-10">
    <div class="flex items-center gap-4 text-sm text-slate-500">
      <%= link_to jobs_path, class: "inline-flex items-center gap-2 text-slate-500 hover:text-slate-900 transition" do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to roles
      <% end %>
      <% if @job.category.present? %>
        <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/70 px-3 py-1 text-xs uppercase tracking-[0.2em]">
          <%= @job.category %>
        </span>
      <% end %>
    </div>

    <div class="rounded-4xl border border-slate-200 bg-white/80 p-8 shadow-2xl shadow-slate-200/80 backdrop-blur">
      <div class="space-y-6">
        <div>
          <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Position Overview</p>
          <h1 class="mt-3 text-4xl font-bold text-slate-900"><%= @job.title %></h1>
          <% if @job.sub_heading.present? %>
            <p class="mt-2 text-lg text-slate-500"><%= @job.sub_heading %></p>
          <% end %>
        </div>

        <div class="flex flex-wrap gap-4 text-sm text-slate-600">
          <% if @job.salary.present? %>
            <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-3.333 0-5 1.333-5 4s1.667 4 5 4 5-1.333 5-4-1.667-4-5-4zm0-4v4m0 8v4" />
              </svg>
              <%= number_to_currency(@job.salary, precision: 0) %>
            </span>
          <% end %>
          <% if @job.location.present? %>
            <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 11a3 3 0 100-6 3 3 0 000 6zm0 0c-4 0-6 2-6 4v1h12v-1c0-2-2-4-6-4z" />
              </svg>
              <%= @job.location %>
            </span>
          <% end %>
          <% @job.benefit_list.each do |benefit| %>
            <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-4 py-2">
              <%= benefit %>
            </span>
          <% end %>
        </div>

        <% if @job.description.present? %>
          <div class="rounded-3xl border border-slate-100 bg-slate-50 p-6 text-slate-600 leading-relaxed">
            <%= simple_format(@job.description, { class: "mb-4 last:mb-0" }, wrapper_tag: "p") %>
          </div>
        <% end %>

        <div class="flex flex-wrap gap-3">
          <button id="applyButton"
            class="inline-flex items-center justify-center rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-slate-900/30 transition hover:bg-slate-800">
            Apply Now
          </button>
          <% if logged_in? %>
            <%= link_to "Edit Role", edit_job_path(@job),
              class: "inline-flex items-center justify-center rounded-full border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100" %>
            <%= link_to "Delete Role", job_path(@job), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
              class: "inline-flex items-center justify-center rounded-full border border-rose-200 px-6 py-3 text-sm font-semibold text-rose-600 transition hover:bg-rose-50" %>
          <% end %>
        </div>
      </div>

      <div id="applyForm" class="mt-10 hidden rounded-3xl border border-slate-200 bg-white/90 p-8 shadow-xl shadow-slate-200/80 backdrop-blur">
        <h2 class="text-2xl font-semibold text-slate-900 mb-6">Apply for <%= @job.title %></h2>
        <%= form_with url: apply_job_path(@job), method: :post, local: true, html: { multipart: true }, class: "space-y-5" do |f| %>
          <div class="grid gap-5 md:grid-cols-2">
            <div>
              <label class="block text-sm font-medium text-slate-600">Full Name</label>
              <%= f.text_field :name, class: "mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200", required: true %>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-600">Phone Number</label>
              <%= f.telephone_field :phone, class: "mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200", required: true %>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-600">Email Address</label>
              <%= f.email_field :email, class: "mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200", required: true %>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-600">Attach Resume (optional)</label>
              <%= f.file_field :resume, class: "mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 text-slate-900 focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600">Message</label>
            <%= f.text_area :message, rows: 4, class: "mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>
          <%= f.submit "Submit Application",
            class: "w-full rounded-2xl bg-slate-900 py-3 text-sm font-semibold text-white shadow-lg shadow-slate-900/30 transition hover:bg-slate-800" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  const initApplyToggle = () => {
    const button = document.getElementById("applyButton")
    const form = document.getElementById("applyForm")
    if (button && form && !button.dataset.enhanced) {
      button.dataset.enhanced = "true"
      button.addEventListener("click", () => {
        form.classList.toggle("hidden")
        button.textContent = form.classList.contains("hidden") ? "Apply Now" : "Hide Application Form"
      })
    }
  }

  document.addEventListener("turbo:load", initApplyToggle)
  document.addEventListener("DOMContentLoaded", initApplyToggle)
</script>
