<!DOCTYPE html>
<html>
  <head>
    <title>Lincd</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js" defer></script>
    <%= javascript_importmap_tags %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-white text-gray-900 font-sans">
    <% if flash[:notice].present? %>
      <div
        id="flash-notice"
        class="fixed top-24 right-6 z-[100] max-w-sm rounded-2xl border border-slate-200 bg-white/95 px-5 py-4 text-sm text-slate-800 shadow-2xl shadow-slate-300/50 backdrop-blur"
        role="status"
        aria-live="polite"
      >
        <div class="flex items-start justify-between gap-4">
          <p class="leading-relaxed"><%= flash[:notice] %></p>
          <button
            type="button"
            class="text-slate-400 transition hover:text-slate-700"
            onclick="document.getElementById('flash-notice')?.remove()"
            aria-label="Close notification"
          >
            &times;
          </button>
        </div>
      </div>
      <script>
        setTimeout(() => document.getElementById("flash-notice")?.remove(), 4000)
      </script>
    <% end %>
    <% if flash[:alert].present? %>
      <div
        id="flash-alert"
        class="fixed top-24 right-6 z-[100] max-w-sm rounded-2xl border border-rose-200 bg-rose-50/95 px-5 py-4 text-sm text-rose-700 shadow-2xl shadow-rose-200/50 backdrop-blur"
        role="alert"
        aria-live="assertive"
      >
        <div class="flex items-start justify-between gap-4">
          <p class="leading-relaxed"><%= flash[:alert] %></p>
          <button
            type="button"
            class="text-rose-400 transition hover:text-rose-700"
            onclick="document.getElementById('flash-alert')?.remove()"
            aria-label="Close alert"
          >
            &times;
          </button>
        </div>
      </div>
      <script>
        setTimeout(() => document.getElementById("flash-alert")?.remove(), 4000)
      </script>
    <% end %>

    <div class="container1">
      <header class="w-full py-4 px-6 flex justify-between items-center shadow-sm fixed top-0 center backdrop-blur-xl z-50">
        <%= link_to root_path, class: "w-1/4 flex items-center" do %>
          <%= image_tag "Lincd_logo.png", alt: "Lincd", class: "h-8 w-auto" %>
        <% end %>
        <nav class="flex-1 flex justify-center space-x-6 text-sm">
          <%= link_to "Clients", clients_path, class: "hover:underline" %>
          <%= link_to "Jobs", jobs_path, class: "hover:underline" %>
          <%= link_to "Apply", apply_path, class: "hover:underline" %>
          <%= link_to "About", about_path, class: "hover:underline" %>
        </nav>
        <div class="w-1/4 flex justify-end">
          <% if logged_in? %>
            <%= button_to "Log out", logout_path, method: :delete,
              class: "inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-4 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50" %>
          <% end %>
        </div>
      </header>
      <main class="w-full <%= controller_name == 'home' && action_name == 'index' ? '' : 'mt-32 px-6' %>">
        <%= yield %>
      </main>

      <div class="h-32"></div><!-- Footer reveal spacer -->
    </div>
    <footer class="site-footer bg-black text-white h-32 py-8 mt-16">
      <div class="container mx-auto text-center">
        <div class="flex flex-col items-center space-y-2">
          <!-- Contact Info -->
          <div class="flex space-x-6 text-sm">
            <a href="mailto:lincoln@lincd.com.au" class="hover:text-blue-400 transition-colors">
              📧 lincoln@lincd.com.au
            </a>
            <a href="tel:0422139652" class="hover:text-blue-400 transition-colors">
              📞 0422 139 652
            </a>
          </div>

          <!-- Copyright -->
          <p class="text-sm">© 2026 Lincd. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
